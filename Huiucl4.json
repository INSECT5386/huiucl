{
  "문법": {
    "수식법": {
      "1": {
        "하다 ([대상]은 [행위어] 한다)": "[대상] [행위어]",
        "했다 ([대상]은 [행위어] 했다)": "[대상] [행위어]k",
        "할 것이다 ([대상]은 [행위어] 할 것이다)": "[대상] [행위어]s",
        "하는": "[대상] [행위어 2형태]",
        "했던": "[대상] [행위어 2형태]k",
        "할": "[대상] [행위어 2형태]s",
        "한": "[상태어 2형태] [대상] | [행위어 2형태] [대상]"
      },
      "2": {
        "하게 하다 ([대상]은 [부사]하게 [행위어] 한다)": "[대상] [부사] [행위어]",
        "하게 했다([대상]은 [부사]하게 [행위어] 했다)": "[대상] [부사] [행위어]k",
        "하게 했다([대상]은 [부사]하게 [행위어] 할 것이다)": "[대상] [부사] [행위어]s",
        "하게 하는": "[부사] [행위어 2형태] [대상]",
        "하게 했던": "[부사] [행위어 2형태]k [대상]",
        "하게 할": "[부사] [행위어 2형태]s [대상]",
        "하게 한": "[부사] [상태어 2형태] [대상] | [부사] [행위어 2형태] [대상]"
      }
    },
    "의문법": {
      "무엇": {
        "1": "[주제] nu hai? ([주제]는 무엇인가?)",
        "2": "hai? (뭐야?)"
      },
      "왜": {
        "1": "[문장] cai? (왜 [문장]입니까?)",
        "2": "cai? (왜?)"
      },
      "어떻게": {
        "1": "[문장] mai? ([문장]을 어떻게 합니까?)",
        "2": "sca mai (어떡해)"
      }
    }
  },

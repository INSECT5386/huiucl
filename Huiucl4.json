  "접사 및 요소": {
    "_zi": {
      "뜻": "진행형",
      "예문": {
        "1": "xi(걷다/운전하다) -> xizi(걷고 있다/운전하고 있다)",
        "2": "xizik(걷고 있었다/운전하고 있었다)",
        "3": "xizis(걷고 있을 것이다/운전하고 있을 것이다)"
      }
    },
    "_tli_": {
      "뜻": "피동형/결과",
      "예문": {
        "1": "chaitla(촬영하다) -> chaitli(촬영되다|사진)",
        "2": "ceit(촬영 되었다)",
        "3": "coit(촬영될 것이다)"
      }
    },
    "_hua": {
      "뜻": "사람",
      "예제": {
        "1": "xi(걷다/운전하다) -> xihua(운전자/이동자)"
      }
    },
    "_tl": {
      "뜻": "도구/물건",
      "예제": {
        "1": "xi(걷다/운전하다) -> xitl(자동차)"
      }
    },
    "_tlan": {
      "뜻": "건물/구조물",
      "예제": {
        "1": "xi(걷다/운전하다) -> xitlan(산책로/도로)"
      }
    },
    "a_": {
      "뜻": "주격",
      "예제": {
        "1": "ni(나) -> ani(나는) | xihua(운전자) -> axihua(과거의 운전자가)",
        "2": "ani kehua ses. (나는 구매자였다.)"
      }
    },
    "[목적어][동사]": {
      "뜻": "목적격",
      "예제": {
        "1": "ani tihatlak, ti se kadzha(나는 그것을 먹었다, 그것은 돼지고기이다.)",
        "2": "ani tituantla, ti se tirn (나는 그것을 잃었다, 그것은 기회이다.)"
      }
    },
    "_no": {
      "뜻": "소유격/속성격",
      "예제": {
        "1": "nino cestli (나의 짐)",
        "2": "henrnno suipane (최대의 기쁨)"
      }
    },
    "_pan": {
      "뜻": "에게/으로/까지(공간)/위해/~동안/에 대해",
      "예제": {
        "1": "ani mipan tikitlas. ( 나는 너에게 그것을 줄 것이다.)",
        "2": "ani kzatlanpan xitlas. ( 나는 집으로 갈 것이다. | 나는 집까지 갈 것이다.)",
        "3": "ani mipan xuantla. ( 나는 너를 위해 노력한다(일한다).)",
        "4": "ani tarunpan sotla. (나는 밤 동안 잘 것이다.)",
        "5": "kuzapan mai cheitla? (죽음에 대해 어떻게 생각하나요?)"
      }
    },
    "pe": {
      "뜻": "까지(시간)/~하게(으로)",
      "예제": {
        "1": "socheitla pe, xuantlapi. (기절할 생각으로 일해라.)",
        "2": "13 kirn pe, kentlapi. (13시까지 와라.)"
      }
    },
    "_id": {
      "뜻": "에서(공간)/부터(공간|물체)",
      "예제": {
        "1": "ani kzatlanid caltlas. (나는 집에서 놀 것이다.)",
        "2": "hiid kiid katlapi. (이것부터 저것까지 버려라.)",
        "3": "niid penatlapi. (나부터 도와라.)"
      }
    },
    "qe": {
      "뜻": "에서(시간)/부터(시간)",
      "예제": {
        "1": "13 kirn qe, tketlapi. (미래의 13시부터 시작해라.)",
        "2": "13 kiron qe, caltlas. (미래의 13시에 놀 것이다.)"
      }
    },
    "_ca": {
      "뜻": "도구격, ~으로",
      "예제": {
        "1": "ani tixuatlak xuatlca, ti se suectl. (나는 무기로 그것을 부쉈다, 그것은 의자이다.)"
      }
    },
    "len": {
      "뜻": "-아니/때문에/의해",
      "예제": {
        "1": "ti len, amaxzn kuzatlak. (그 때문에, 사람들이 죽었다. | 그에 의해 사람들이 죽었다.)",
        "2": "ani se maxn len, petlanpan xitla. (나는 사람이기 때문에, 학교에 간다.)"
      }
    },
    "_z": {
      "뜻": "복수형",
      "예문": {
        "1": "maxn(사람) -> maxzn(사람들)",
        "2": "xatlazn (건물 들)"
      }
    },
    "_pi": {
      "뜻": "-해라",
      "예문": {
        "1": "xitlapi (가라/운전해라/걸어라)"
      }
    }
  },

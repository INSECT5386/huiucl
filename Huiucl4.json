{
  "문법": {
    "수식법": {
      "1": {
        "하다 ([대상]은 [행위어] 한다)": "[대상] [행위어]",
        "했다 ([대상]은 [행위어] 했다)": "[대상] [행위어] - [해당 품사를 나타내는 접사] + akl",
        "할 것이다 ([대상]은 [행위어] 할 것이다)": "[대상] [행위어] - [해당 품사를 나타내는 접사] + ad",
        "하는": "[대상] [현재분사화 행위어]",
        "했던": "[대상] [과거분사화 행위어]",
        "할": "[대상] [미래분사화 행위어]",
        "한": "[대상] [상태어] | [대상] [행위어] - [해당 품사를 나타내는 접사] + ach",
        "예문": {
          "1": "An maqe | An uiso (나는 생존한다. | 나는 빠르다.)",
          "2": "An maqakl | An uisakl  (나는 생존했다. | 나는 빨랐다.)",
          "3": "An maqad | An uisad (나는 생존할 것이다. | 나는 빠를 것이다.)",
          "4": "An la il maqe (나는 생존하는 사람이다.)",
          "5": "An la il maqakl (나는 생존했던 사람이다.)",
          "6": "An la il maqad (나는 생존할 사람이다.)",
          "7": "An la il uisano | Un la naml ecultach (나는 느린 사람이다. | 그것은 연속한 숫자이다.)"
        }
      },
      "2": {
        "하게 하다 ([대상]은 [부사]하게 [행위어] 한다)": "[대상] [부사] [행위어]",
        "하게 했다([대상]은 [부사]하게 [행위어] 했다)": "[대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + akl",
        "하게 했다([대상]은 [부사]하게 [행위어] 할 것이다)": "[대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + ad",
        "하게 하는": "[대상] [부사] [현재분사화 행위어]",
        "하게 했던": "[대상] [부사] [과거분사화 행위어]",
        "하게 할": "[대상] [부사] [미래분사화 행위어]",
        "하게 한": "[대상] [부사] [상태어] | [대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + ach",
        "예문": {
          "1": "Uan uisano ote | Uan alci malo (그것은 느리게 작동한다. | 그것은 아주 똑똑하다.)",
          "2": "Uan uisano otakl | Uan alci malakl (그것은 느리게 작동했다. | 그것은 아주 똑똑했다.)",
          "3": "Uan uisano otad | Uan alci malad (그것은 느리게 작동할 것이다. | 그것은 아주 똑똑할 것이다)",
          "4": "Uan la ichuali uisano ote (그것은 느리게 작동하는 기계이다.)",
          "5": "Uan ichuali uisano otakl (그것은 느리게 작동했던 기계이다.)",
          "6": "Uan ichuali uisano otad (그것은 느리게 작동할 기계이다.)",
          "7": "Uan la il alci uisano. | Uan la naml oto ecultach (그것은 아주 느린 사람이다. | 그것은 길게 연속한 숫자이다.)"
        }
      },
      "3": {
        "[대상] 의  (소유격)": "'o [대상]",
        "[대상] 의  (속성격)": " ol [대상]",
        "[대상] 이/가": "[대상]ts"
      }
    },
    "평문법": {
      "1": {
        "[대상]은 [물체]이다": "[대상] la [물체]",
        "[대상]은 [물체]가 아니다": "[대상] lam'tl [물체]",
        "[대상]은 [행위어]를 하고 있다": "[대상] laka [행위어]",
        "[대상](은는/이가) [물체]가 되다": "[대상] [물체]ts lakla",
        "예문": {
          "1": "An la il (나는 사람이다.)",
          "2": "An lam'tl il (나는 사람이 아니다.)",
          "3": "An laka maqe (나는 살고 있다.)",
          "4": "maqalits ilts lakla (동물이 사람이 되다.)"
        }
      },
      "2": {
        "[대상]은 를 할 수 있다": "[대상] luca m",
        "[대상]은 를 할 수 없다": "[대상] lucam'tl m",
        "[대상]은 를 할 수도 있다": "[대상] clu m",
        "[대상]은 를 하지 않을 수도 있다": "[대상] clum'tl m",
        "예문": {
          "1": "An luca uam (나는 그것을 할 수 있다.)",
          "2": "An lucam'tl uam (나는 그것을 할 수 없다.)",
          "3": "An clu uam (나는 그것을 할 수도 있다.)",
          "4": "An clum'tl uam (나는 그것을 하지 않을 수도 있다.)"
        }
      },
      "3": {
        "[대상]은 를 하는 것이 좋겠다": "[대상] sana m",
        "[대상]은 를 하지 않는 것이 좋겠다": "[대상] sanam'tl m",
        "[대상]은 를 해야 한다": "[대상] casa m",
        "[대상]은 를 해야만 한다": "[대상] kau m",
        "[대상]은 를 할 필요가 없다": "[대상] m kaum'tl",
        "예문": {
          "1": "In sana uam (너는 그것을 하는 것이 좋겠다.)",
          "2": "In sanam'tl uam (너는 그것을 하지 않는 것이 좋겠다.)",
          "3": "An casa uam (나는 그것을 해야한다.)",
          "4": "An kau uam (나는 그것을 해야만 한다.)",
          "5": "An kaum'tl uam (나는 그것을 할 필요가 없다.)"
        }
      },
      "4": {
        "[대상]은 를 하고 싶다/원하다": "[대상] ina m",
        "[대상]은 를 하기 싫다/원하지 않는다": "[대상] inam'tl m",
        "[대상]은 [인물]가 를 하기 원한다": "[대상] [인물]ts ina m",
        "[대상]은 [인물]가 를 하지 않길 원한다": "[대상] [인물]ts inam'tl m",
        "예문": {
          "1": "An ina etem (나는 음식을 원한다.)",
          "2": "An inam'tl etem (나는 음식을 원하지 않는다.)",
          "3": "An uts ina uam (나는 그가 그것을 하길 원한다.)",
          "4": "An uts inam'tl uam (나는 그가 그것을 하지 않길 원한다.)"
        }
      },
      "5": {
        "[대상]은 [물체]가 필요하다": "[대상] [물체]ts mato",
        "[대상]은 [물체]가 불필요하다": "[대상] [물체]ts matano",
        "[대상]은 를 하지 않다": "[대상] m scam'tl",
        "[대상]은 를 하지 않았다": "[대상] m scaklm'tl",
        "[대상]은 하지 않을 것이다": "[대상] m scadm'tl",
        "예문": {
          "1": "An etets mato (나는 음식이 필요하다.)",
          "2": "An etets matano (나는 음식이 필요하지 않는다.)"
        }
      }
    },
    "의문법": {
      "무엇": {
        "1": "slan [주제] nu hlai? ([주제]는 무엇인가?)",
        "2": "slan hlai? (뭐야?)"
      },
      "왜": {
        "1": "slan [문장] taci? (왜 [문장]입니까?)",
        "2": "slan taci? (왜?)"
      },
      "어떻게": {
        "1": "slan [문장] maci? ([문장]을 어떻게 합니까?)",
        "2": "slan sca maci (어떡해)"
      }
    },
    "명령법": {
      "[문장] 해라": "sta [문장]"
    },
    "접속법": {
      "만약  이라면": "ul ",
      " 그리고, ": "[문장], [문장] ",
      " 하지만, ": " tan ",
      "그러면,": " kan ", 
      " 그러며, ": " lan ",
      " 그러자, ": " han ",
      "그래서": "[문장1] tsan [문장2]",
      "[원인] 때문에  [결과]": "[결과] quan [원인]",
      "[누구]에 의해": "quan [누구]",
      "[누구] 에게": "tlun [누구]",
      "[장소] 으로": "tlun [장소]",
      "[시간/장소] 까지": "tlun [시간/장소]",
      "[누구]를 위해": "tlun [누구]",
      "[시간] 동안": "tlun [시간]",
      "[시간/장소] 에서/부터": "luan [시간/장소]"
    }
  },

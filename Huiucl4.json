{
  "문법": {
    "수식법": {
      "1": {
        "하다 ([대상]은 [행위어] 한다)": "[대상] [행위어]",
        "하다 ([대상]은 [상태어] 한다)": "[대상] [상태어] sca",
        "했다 ([대상]은 [행위어] 했다)": "[대상] [행위어]v",
        "했다 ([대상]은 [상태어] 했다)": "[대상] [상태어] scav",
        "할 것이다 ([대상]은 [행위어] 할 것이다)": "[대상] [행위어]d",
        "할 것이다 ([대상]은 [상태어] 할 것이다)": "[대상] [상태어] scad",
        "하는": "[대상] [현재분사화 행위어]",
        "한 (1)": "[대상] [상태어]",
        "했던": "[대상] [과거분사화 행위어]",
        "한 (2)": "[대상] [형용사화 행위어]",
        "할": "[대상] [미래분사화 행위어]",
        "예문": {
          "1": "An elu (나는 생존한다.)",
          "2": "An hesa sca (나는 빠르다.)",
          "3": "An eluv  (나는 생존했다.)",
          "4": "An hesa scav (나는 빨랐다.)",
          "5": "An elud (나는 생존할 것이다.)",
          "6": "An hesa scad (나는 빠를 것이다)",
          "7": "An culm icmihle kosug la (나는 언어를 연구하는 사람이다.)",
          "8": "icmihle talaj (약한 사람)",
          "9": "icmihle alue (이동했던 사람)",
          "10": "naml ceyenubl (연속한 숫자)",
          "11": "icmihle aludl (이동할 사람)"
        }
      },
      "2": {
        "하게 하다 ([대상]은 [부사]하게 [행위어] 한다)": "[대상] [행위어] [부사]",
        "하게 하다 ([대상]은 [부사하게] [상태어] 한다)": "[대상] [상태어] [부사] sca",
        "하게 했다([대상]은 [부사]하게 [행위어] 했다)": "[대상] [행위어]v [부사]",
        "하게 했다([대상]은 [부사]하게 [상태어] 했다)": "[대상] [상태어] [부사] scav",
        "하게 했다([대상]은 [부사]하게 [행위어] 할 것이다)": "[대상] [행위어]d [부사]",
        "하게 했다([대상]은 [부사]하게 [상태어] 할 것이다)": "[대상] [상태어] [부사] scad",
        "하게 하는": "[대상] [현재분사화 행위어] [부사]",
        "하게 한 (1)": "[대상] [상태어] [부사]",
        "하게 했던": "[대상] [과거분사화 행위어]",
        "하게 한 (2)": "[대상] [형용사화 행위어]", 
        "하게 할": "[대상] [미래분사화 행위어] [부사]",
        "예문": {
          "1": "Uan palu jamajo (그것은 불공평하게 작동한다.)",
          "2": "Uan qana amaci sca (그것은 매우 화려하다.)",
          "3": "Uan paluv jamajo (그것은 불공평하게 작동했다.)",
          "4": "Uan qana amaci scav (그것은 매우 화려했다.)",
          "5": "Uan palud jamajo (그것은 불공평하게 작동할 것이다.)",
          "6": "Uan qana amaci scad (그것은 매우 화려할 것이다)",
          "7": "Uan ichuc palug jamajo la (그것은 불공평하게 작동하는 기계이다.)",
          "8": "Uan siluve qana amaci la (그것은 매우 화려한 물건이다.)",
          "9": "Uan ichuc palue jamajo la (그것은 불공평하게 작동했던 기계이다.)",
          "10": "Uan naml ceyenubl itici la (그것은 아마도 연속한 숫자이다.)",
          "11": "Uan ichuc paludl jamajo la (그것은 불공평하게 작동할 기계이다.)"
        }
      },
      "3": {
        "[대상] 의  (소유격)": "'o [대상]",
        "[대상] 의  (속성격)": " ol [대상]",
        "[대상] 이/가": "[대상]ng"
      }
    },
    "평문법": {
      "1": {
        "[대상]은 [물체]이다": "[대상] [물체] la",
        "[대상]은 [물체]가 아니다": "[대상] [물체] laj",
        "[대상]은 [행위어]를 하고 있다": "[대상] [행위어] lage",
        "[대상](은는/이가) [물체]가 되다": "[대상] [물체]ng lave",
        "예문": {
          "1": "An icmihle la (나는 사람이다.)",
          "2": "An icmihle laj (나는 사람이 아니다.)",
          "3": "An elu lage(나는 살고 있다.)",
          "4": "althng icmihleng lave (동물이 사람이 되다.)"
        }
      },
      "2": {
        "[대상]은 를 할 수 있다": "[대상] m luca",
        "[대상]은 를 할 수 없다": "[대상] m lucaj",
        "[대상]은 를 할 수도 있다": "[대상] m clu",
        "[대상]은 를 하지 않을 수도 있다": "[대상] m cluju",
        "예문": {
          "1": "An uam luca (나는 그것을 할 수 있다.)",
          "2": "An uam lucaj (나는 그것을 할 수 없다.)",
          "3": "An uam clu (나는 그것을 할 수도 있다.)",
          "4": "An uam cluju (나는 그것을 하지 않을 수도 있다.)"
        }
      },
      "3": {
        "[대상]은 를 하는 것이 좋겠다": "[대상] m sana",
        "[대상]은 를 하지 않는 것이 좋겠다": "[대상] m sanaj",
        "[대상]은 를 해야 한다": "[대상] m casa",
        "[대상]은 를 해야만 한다": "[대상] m geu",
        "[대상]은 를 할 필요가 없다": "[대상] m geuju",
        "예문": {
          "1": "In uam saua (너는 그것을 하는 것이 좋겠다.)",
          "2": "In uam sanaj (너는 그것을 하지 않는 것이 좋겠다.)",
          "3": "An uam casa (나는 그것을 해야한다.)",
          "4": "An uam geu (나는 그것을 해야만 한다.)",
          "5": "An uam geuju (나는 그것을 할 필요가 없다.)"
        }
      },
      "4": {
        "[대상]은 를 하고 싶다/원하다": "[대상] m ina",
        "[대상]은 를 하기 싫다/원하지 않는다": "[대상] m inaj",
        "[대상]은 [인물]가 를 하기 원한다": "[대상] [인물]ng m ina",
        "[대상]은 [인물]가 를 하지 않길 원한다": "[대상] [인물]ng m inaj",
        "예문": {
          "1": "An nuhulm ina (나는 음식을 원한다.)",
          "2": "An nuhulm inaj (나는 음식을 원하지 않는다.)",
          "3": "An ung uam ina (나는 그가 그것을 하길 원한다.)",
          "4": "An ung uam inaj (나는 그가 그것을 하지 않길 원한다.)"
        }
      },
      "5": {
        "[대상]은 [물체]가 필요하다": "[대상] [물체]ng meta sca",
        "[대상]은 [물체]가 필요하지 않다": "[대상] [물체]ng meta scaj",
        "[대상]은 를 하지 않다": "[대상] m scaj",
        "[대상]은 를 하지 않았다": "[대상] m scavj",
        "[대상]은 하지 않을 것이다": "[대상] m scadj",
        "예문": {
          "1": "An nuhulng meta sca (나는 음식이 필요하다.)",
          "2": "An nuhulng meta scaj (나는 음식이 필요하지 않는다.)"
        }
      }

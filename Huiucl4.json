{
  "문법": {
    "1": "동사는 어근 끝에'a'가 붙으면, 현재형. 'e'가 붙으면, 과거형, 'o'가 붙으면 미래형이다.",
    "수식법": {
      "1": {
        "하다 ([대상]은 [행위어] 한다)": "[대상] [행위어]",
        "했다 ([대상]은 [행위어] 했다)": "[대상] [행위어] - [해당 품사를 나타내는 접사] + akr",
        "할 것이다 ([대상]은 [행위어] 할 것이다)": "[대상] [행위어] - [해당 품사를 나타내는 접사] + ad",
        "하는": "[대상] [현재분사화 행위어]",
        "했던": "[대상] [과거분사화 행위어]",
        "할": "[대상] [미래분사화 행위어]",
        "한": "[대상] [상태어] | [대상] [행위어] - [해당 품사를 나타내는 접사] + ach",
        "예문": {
          "1": "An maqe | An uiso (나는 생존한다. | 나는 빠르다.)",
          "2": "An maqakr | An uisakr  (나는 생존했다. | 나는 빨랐다.)",
          "3": "An maqad | An uisad (나는 생존할 것이다. | 나는 빠를 것이다.)",
          "4": "An ra ir maqe (나는 생존하는 사람이다.)",
          "5": "An ra ir maqakr (나는 생존했던 사람이다.)",
          "6": "An ra ir maqad (나는 생존할 사람이다.)",
          "7": "An ra ir uisano | Un ra namr ecurtach (나는 느린 사람이다. | 그것은 연속한 숫자이다.)"
        }
      },
      "2": {
        "하게 하다 ([대상]은 [부사]하게 [행위어] 한다)": "[대상] [부사] [행위어]",
        "하게 했다([대상]은 [부사]하게 [행위어] 했다)": "[대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + akr",
        "하게 했다([대상]은 [부사]하게 [행위어] 할 것이다)": "[대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + ad",
        "하게 하는": "[대상] [부사] [현재분사화 행위어]",
        "하게 했던": "[대상] [부사] [과거분사화 행위어]",
        "하게 할": "[대상] [부사] [미래분사화 행위어]",
        "하게 한": "[대상] [부사] [상태어] | [대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + ach",
        "예문": {
          "1": "Uan uisano ote | Uan arci maro (그것은 느리게 작동한다. | 그것은 아주 똑똑하다.)",
          "2": "Uan uisano otakr | Uan arci marakr (그것은 느리게 작동했다. | 그것은 아주 똑똑했다.)",
          "3": "Uan uisano otad | Uan arci marad (그것은 느리게 작동할 것이다. | 그것은 아주 똑똑할 것이다)",
          "4": "Uan ra ichuari uisano ote (그것은 느리게 작동하는 기계이다.)",
          "5": "Uan ichuari uisano otakr (그것은 느리게 작동했던 기계이다.)",
          "6": "Uan ichuari uisano otad (그것은 느리게 작동할 기계이다.)",
          "7": "Uan ra ir arci uisano. | Uan ra namr oto ecurtach (그것은 아주 느린 사람이다. | 그것은 길게 연속한 숫자이다.)"
        }
      },
      "3": {
        "[대상] 의  (소유격)": "'o [대상]",
        "[대상] 의  (속성격)": " or [대상]",
        "[대상] 이/가": "[대상]ts"
      }
    },
    "평문법": {
      "1": {
        "[대상]은 [물체]이다": "[대상] ra [물체]",
        "[대상]은 [물체]가 아니다": "[대상] ram'tr [물체]",
        "[대상]은 [행위어]를 하고 있다": "[대상] raka [행위어]",
        "[대상](은는/이가) [물체]가 되다": "[대상] [물체]ts rakra",
        "예문": {
          "1": "An ra ir (나는 사람이다.)",
          "2": "An ram'tr ir (나는 사람이 아니다.)",
          "3": "An raka maqe (나는 살고 있다.)",
          "4": "maqarits irts rakra (동물이 사람이 되다.)"
        }
      },
      "2": {
        "[대상]은 를 할 수 있다": "[대상] ruca m",
        "[대상]은 를 할 수 없다": "[대상] rucam'tr m",
        "[대상]은 를 할 수도 있다": "[대상] cru m",
        "[대상]은 를 하지 않을 수도 있다": "[대상] crum'tr m",
        "예문": {
          "1": "An ruca uam (나는 그것을 할 수 있다.)",
          "2": "An rucam'tr uam (나는 그것을 할 수 없다.)",
          "3": "An cru uam (나는 그것을 할 수도 있다.)",
          "4": "An crum'tr uam (나는 그것을 하지 않을 수도 있다.)"
        }
      },
      "3": {
        "[대상]은 를 하는 것이 좋겠다": "[대상] sana m",
        "[대상]은 를 하지 않는 것이 좋겠다": "[대상] sanam'tr m",
        "[대상]은 를 해야 한다": "[대상] casa m",
        "[대상]은 를 해야만 한다": "[대상] kau m",
        "[대상]은 를 할 필요가 없다": "[대상] m kaum'tr",
        "예문": {
          "1": "In sana uam (너는 그것을 하는 것이 좋겠다.)",
          "2": "In sanam'tr uam (너는 그것을 하지 않는 것이 좋겠다.)",
          "3": "An casa uam (나는 그것을 해야한다.)",
          "4": "An kau uam (나는 그것을 해야만 한다.)",
          "5": "An kaum'tr uam (나는 그것을 할 필요가 없다.)"
        }
      },
      "4": {
        "[대상]은 를 하고 싶다/원하다": "[대상] ina m",
        "[대상]은 를 하기 싫다/원하지 않는다": "[대상] inam'tr m",
        "[대상]은 [인물]가 를 하기 원한다": "[대상] [인물]ts ina m",
        "[대상]은 [인물]가 를 하지 않길 원한다": "[대상] [인물]ts inam'tr m",
        "예문": {
          "1": "An ina etem (나는 음식을 원한다.)",
          "2": "An inam'tr etem (나는 음식을 원하지 않는다.)",
          "3": "An uts ina uam (나는 그가 그것을 하길 원한다.)",
          "4": "An uts inam'tr uam (나는 그가 그것을 하지 않길 원한다.)"
        }
      },
      "5": {
        "[대상]은 [물체]가 필요하다": "[대상] [물체]ts mato",
        "[대상]은 [물체]가 불필요하다": "[대상] [물체]ts matano",
        "[대상]은 를 하지 않다": "[대상] m scam'tr",
        "[대상]은 를 하지 않았다": "[대상] m scakrm'tr",
        "[대상]은 하지 않을 것이다": "[대상] m scadm'tr",
        "예문": {
          "1": "An etets mato (나는 음식이 필요하다.)",
          "2": "An etets matano (나는 음식이 필요하지 않는다.)"
        }
      }
    },
    "의문법": {
      "무엇": {
        "1": "sran [주제] nu hrai? ([주제]는 무엇인가?)",
        "2": "sran hrai? (뭐야?)"
      },
      "왜": {
        "1": "sran [문장] taci? (왜 [문장]입니까?)",

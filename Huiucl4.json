  "조동사": {
    "qar | qer | qor": "할 수 있다 | 할 수 있었다 | 할 수 있을 것이다",
    "shar | sher | shor": "하는 것이 좋다 | 하는 것이 좋았다 | 하는 것이 좋을 것이다",
    "thar | ther | thor": "해야 한다 | 해야 했다 | 해야 할 것이다",

{
  "문법": {
    "수식법": {
      "1": {
        "하다 ([대상]은 [행위어] 한다)": "[대상] [행위어]",
        "했다 ([대상]은 [행위어] 했다)": "[대상] [행위어] - [해당 품사를 나타내는 접사] + av",
        "할 것이다 ([대상]은 [행위어] 할 것이다)": "[대상] [행위어] - [해당 품사를 나타내는 접사] + ad",
        "하는": "[대상] [현재분사화 행위어]",
        "했던": "[대상] [과거분사화 행위어]",
        "할": "[대상] [미래분사화 행위어]",
        "한": "[대상] [상태어] | [대상] [행위어] - [해당 품사를 나타내는 접사] + ach",
        "예문": {
          "1": "An maqui | An huisaho (나는 생존한다. | 나는 빠르다.)",
          "2": "An maqav | An huisahav  (나는 생존했다. | 나는 빨랐다.)",
          "3": "An maqad | An huisahad (나는 생존할 것이다. | 나는 빠를 것이다.)",
          "4": "An la ili maqui (나는 생존하는 사람이다.)",
          "5": "An la ili maqav (나는 생존했던 사람이다.)",
          "6": "An la ili maqad (나는 생존할 사람이다.)",
          "7": "An la ili huisaho | Un la naml coacilach (나는 느린 사람이다. | 그것은 연속한 숫자이다.)"
        }
      },
      "2": {
        "하게 하다 ([대상]은 [부사]하게 [행위어] 한다)": "[대상] [부사] [행위어]",
        "하게 했다([대상]은 [부사]하게 [행위어] 했다)": "[대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + av",
        "하게 했다([대상]은 [부사]하게 [행위어] 할 것이다)": "[대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + ad",
        "하게 하는": "[대상] [부사] [현재분사화 행위어]",
        "하게 했던": "[대상] [부사] [과거분사화 행위어]",
        "하게 할": "[대상] [부사] [미래분사화 행위어]",
        "하게 한": "[대상] [부사] [상태어] | [대상] [부사] [행위어] - [해당 품사를 나타내는 접사] + ach",
        "예문": {
          "1": "Uan huisaho motui | Uan alci malo (그것은 느리게 작동한다. | 그것은 아주 똑똑하다.)",
          "2": "Uan huisaho motav | Uan alci malav (그것은 느리게 작동했다. | 그것은 아주 똑똑했다.)",
          "3": "Uan huisaho motad | Uan alci malad (그것은 느리게 작동할 것이다. | 그것은 아주 똑똑할 것이다)",
          "4": "Uan la ichuc huisaho motui (그것은 느리게 작동하는 기계이다.)",
          "5": "Uan ichuc huisaho motav (그것은 느리게 작동했던 기계이다.)",
          "6": "Uan ichuc huisaho motad (그것은 느리게 작동할 기계이다.)",
          "7": "Uan la ili alci huisaho. | Uan la naml tuito coacilach (그것은 아주 느린 사람이다. | 그것은 길게 연속한 숫자이다.)"
        }
      },
      "3": {
        "[대상] 의  (소유격)": "'o [대상]",
        "[대상] 의  (속성격)": " ol [대상]",
        "[대상] 이/가": "[대상]ng"
      }
    },
    "평문법": {
      "1": {
        "[대상]은 [물체]이다": "[대상] la [물체]",
        "[대상]은 [물체]가 아니다": "[대상] laj [물체]",
        "[대상]은 [행위어]를 하고 있다": "[대상] laka [행위어]",
        "[대상](은는/이가) [물체]가 되다": "[대상] [물체]ng lava",
        "예문": {
          "1": "An la ili (나는 사람이다.)",
          "2": "An laj ili (나는 사람이 아니다.)",
          "3": "An laka maqui (나는 살고 있다.)",
          "4": "althng iling lava (동물이 사람이 되다.)"
        }
      },
      "2": {
        "[대상]은 를 할 수 있다": "[대상] luca m",
        "[대상]은 를 할 수 없다": "[대상] lucaj m",
        "[대상]은 를 할 수도 있다": "[대상] clu m",
        "[대상]은 를 하지 않을 수도 있다": "[대상] cluju m",
        "예문": {
          "1": "An luca uam (나는 그것을 할 수 있다.)",
          "2": "An lucaj uam (나는 그것을 할 수 없다.)",
          "3": "An clu uam (나는 그것을 할 수도 있다.)",
          "4": "An cluju uam (나는 그것을 하지 않을 수도 있다.)"
        }
      },
      "3": {
        "[대상]은 를 하는 것이 좋겠다": "[대상] sana m",
        "[대상]은 를 하지 않는 것이 좋겠다": "[대상] sanaj m",
        "[대상]은 를 해야 한다": "[대상] casa m",
        "[대상]은 를 해야만 한다": "[대상] kau m",
        "[대상]은 를 할 필요가 없다": "[대상] m kauju",
        "예문": {
          "1": "In sana uam (너는 그것을 하는 것이 좋겠다.)",
          "2": "In sanaj uam (너는 그것을 하지 않는 것이 좋겠다.)",
          "3": "An casa uam (나는 그것을 해야한다.)",
          "4": "An kau uam (나는 그것을 해야만 한다.)",
          "5": "An kauju uam (나는 그것을 할 필요가 없다.)"
        }
      },
      "4": {
        "[대상]은 를 하고 싶다/원하다": "[대상] m ina",
        "[대상]은 를 하기 싫다/원하지 않는다": "[대상] m inaj",
        "[대상]은 [인물]가 를 하기 원한다": "[대상] [인물]ng m ina",
        "[대상]은 [인물]가 를 하지 않길 원한다": "[대상] [인물]ng m inaj",
        "예문": {
          "1": "An ina cuacuim (나는 음식을 원한다.)",
          "2": "An inaj cuacuim (나는 음식을 원하지 않는다.)",
          "3": "An ung ina uam (나는 그가 그것을 하길 원한다.)",
          "4": "An ung inaj uam (나는 그가 그것을 하지 않길 원한다.)"
        }
      },
      "5": {
        "[대상]은 [물체]가 필요하다": "[대상] [물체]ng mato",
        "[대상]은 [물체]가 필요하지 않다": "[대상] [물체]ng matoj",
        "[대상]은 를 하지 않다": "[대상] m scaj",
        "[대상]은 를 하지 않았다": "[대상] m scavj",
        "[대상]은 하지 않을 것이다": "[대상] m scadj",
        "예문": {
          "1": "An cuacuing mato (나는 음식이 필요하다.)",
          "2": "An cuacuing matoj (나는 음식이 필요하지 않는다.)"
        }
      }
    },
    "의문법": {
      "무엇": {
        "1": "[주제] nu hlai? ([주제]는 무엇인가?)",
        "2": "hlai? (뭐야?)"
      },
      "왜": {
        "1": "[문장] taci? (왜 [문장]입니까?)",
        "2": "taci? (왜?)"
      },
      "어떻게": {
        "1": "[문장] maci? ([문장]을 어떻게 합니까?)",
        "2": "sca maci (어떡해)"
      }
    },
    "명령법": {
      "[문장] 해라": "sta [문장]"
    },
    "접속법": {
      "만약  이라면": "ul ",
      " 그리고, ": "[문장], [문장] ",
      " 하지만, ": " ot ",
      " 그러며, ": " al ",
      " 그러자, ": " ag ",
      "그래서": "[문장1] sln [문장2]",
      "[원인] 때문에  [결과]": "[결과] ail [원인]",
      "[대상 ]에게": "ux [대상]",
      "[장소] 으로 ('장소' 으로)": "ta [장소]",
      "[장소] 에서": "yux [장소]",
      "[목적/대상]을 위해": "wax [목적/대상]",
      "[무언가]를 하는 동안/[기간] 동안": "tam [무언가/기간]"
    }

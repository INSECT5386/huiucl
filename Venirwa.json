{
  "문법": {
    "수식법": {
      "1": {
        "예문": {
          "1": "puelni pelkatzlixuarn haliospochlitn pelcolivxuarmat. (평범한 나는 특별한 돼지를 세계의 왼쪽에서 특별한 톱으로 죽일 것이다.)",
          "2": "zuatrti tartzliharnk xirimtn. (잔인한 그는 산책로에서 새를 먹었다.)",
          "3": "wase chorkirvarli. (사람은 생각하는 동물이다.)",
          "4": "titaxk wavuarns. (과거분사: 그것을 만졌던 사람은 죽을 것이다.)",
          "5": "mise titaxkwa. (그것을 만질 사람은 너다. - 너는 그것을 만질 사람이다.)",
          "6": "puelni nupoarnk haliospochlitn nu petlwa xuarmakiorn titn. (평범한 나는 세계의 왼쪽에서 뚱뚱한 사람이 그에게 무기를 주는 걸 보았다.)",
          "7": "nirm mi | serm (나 그리고, 너 | 그리고)"
        }
      }
    },
    "의문법": {
      "무엇": {
        "1": "[주제]nt hea? ([주제]는 무엇인가?)",
        "2": "hea? (뭐야?)",
        "예문": {
          "1": "want hea? (사람이 무엇인가요?)"
        }
      },
      "왜": {
        "1": "[문장]nt xea? (왜 [문장]입니까?)",
        "2": "xea? (왜?)",
        "예문": {
          "1": "miwasent xea? (왜 너는 사람입니까?)"
        }
      },
      "어떻게": {
        "1": "[문장]nt mea? ([문장]을 어떻게 합니까?)",
        "2": "sca mea (어떡해)"
      }
    }

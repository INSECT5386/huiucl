{
  "문법": {
    "어순": {
      "일반문 [주어 수식 + 주어] [부사어 + 행위 명사] [목적어 수식 + 목적어] [기타 부사구]": {
        "en uthadeum av uxem o mapem as atzli haliospoxlit fu coxet": "나는 특별한 돼지를 끔찍하게 죽일 것이다 세계의 왼쪽에서 톱으로",
        "it sa chosem an ali.": "사람은 이다 생각하는 동물",
        "en koim o ti seu mi.": "나는 그것을 줄 것이다 너에게",
        "en cabram o 13 kilite.": "나는 놀 것이다 13시에"
      },
      "복합문 [주어 수식 + 주어] [부사어 + 행위 명사] [배경 정보] nu [하위 문장]": {
        "en brum e haliospoxlit nu tam as it koim a uxet seu ti.": "나는 보았다 세상의 왼쪽에서 (nu 이하를) 뚱뚱한 사람이 무기를 주다 그에게"
      },
      "목적문 [주어 수식 + 주어] [부사어1 + 행위 명사1] [목적어 수식1 + 목적어1] no [목적어 수식2 + 목적어2] [부사어2 + 행위 명사2]": {
        "uthadeum as ti utham av kobrum a ti no uxem e pecam as akli.": "끔찍한 그는 멍청한 그것을 잔인하게 때리다 (위해) 귀여운 고양이를 죽일 것이다."
      },
      "명령문 ([주어 수식 + 주어]) [목적어 수식 목적어] [부사어 + 동사]mt [기타 부사구]": {
        "ustram as mi berum amt tam as it teumat.": "멍청한 너는 뚱뚱한 사람을 도와라. 학교에서"
      },
      "이유/피동문 [대상 수식 + 대상] len, [주어 수식 + 주어] [부사어 + 동사] [기타 부사구]": {
        "ti len, dram as itz dram av betem e.": "그 때문에, 많은 사람들이 많이 다쳤다 집에서",
        "en se it len, en xam a teumat.": "나는 이다 사람 때문에, 나는 간다 학교에"
      },
      "이외 문법": {
        "mi srem amt chosem ellet uxem a atzli fu coxet, no haim a ali": "너는 생각을 말해라 에 대하여 돼지를 죽이는 것, 고기를 먹기 위해"
      }
    },
    "의문법": {
      "무엇": {
        "1": "[주제]nt hea? ([주제]는 무엇인가?)",
        "2": "hea? (뭐야?)"
      },
      "왜": {
        "1": "[문장]nt xea? (왜 [문장]입니까?)",
        "2": "xea? (왜?)",
        "3": "chornt mea ellet ubamim? (죽음에 대해 어떻게 생각하나요?)"
      },
      "어떻게": {
        "1": "[문장]nt mea? ([문장]을 어떻게 합니까?)",
        "2": "sca mea (어떡해)"
      }
    }
  },

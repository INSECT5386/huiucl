{
  "문법": {
    "규칙": {
      "1": "'부사' 와 '동사(또는 서술어 역할의 형용사)'의 시제는 통일한다. 단, 명사에게 상태를 수식하는 형용사는 시제를 'a'로 고정한다."
    },
    "어순": {
      "일반문 | [주어 수식] [주어] [부사어] [행위 명사] [목적어 수식] [목적어] [기타 부사구]": {
        "en arlaa akrias atain erunt.": "나는 보살핀다 귀여운 돼지를",
        "elt sa apean ain.": "사람은 이다 생각하는 동물",
        "en oknao el seu mi.": "나는 그것을 줄 것이다 너에게",
        "en ochio 13 kilite.": "나는 놀 것이다 13시에"
      },
      "복합문 | [주어 수식] [주어] [부사어] [행위 명사] [배경 정보] nu [하위 문장]": {
        "en evrue haliospoxlit nu ataas elt aknaa witarsam seu el.": "나는 보았다 세상의 왼쪽에서 (nu 이하를) 뚱뚱한 사람이 무기를 주다 그에게"
      },
      "목적문 | [주어 수식] [주어] [부사어1] [행위 명사1] [목적어 수식1] [목적어1] no [목적어 수식2] [목적어2] [부사어2] [행위 명사2]": {
        "wathapean el wathamas azloa wastraa el no worsao akrias akli.": "끔찍한 그는 멍청한 그것을 잔인하게 때리다 (위해) 귀여운 고양이를 죽일 것이다."
      },
      "요청문 | [주어 수식] [주어] [행위 명사] -mt [목적어 수식] [목적어] [부사어] [기타 부사구]": {
        "mi wahaamt ilihan no el": "당신는 요리해주세요 음식을. 그들을 위해"
      },
      "이유/피동문 | [대상 수식] [대상] len, [주어 수식] [주어] [부사어] [행위 명사] [기타 부사구]": {
        "el len, atveas eltz atveav elkee event.": "그 때문에, 많은 사람들이 많이 다쳤다 집에서",
        "en se elt len, en ashea ekrnunt.": "나는 이다 사람 때문에, 나는 간다 학교에"
      },
      "명령문 | esprt [주어 수식] [주어] [행위 명사] [목적어 수식] [목적어] [부사어] [기타 부사구]": {
        "Esprt wastraas mi arlaa ataas elt ekrnunt.": "멍청한 너는 뚱뚱한 사람을 도와라. 학교에서"
      },
      "이외 문법": {
        "Esprt mi asrea ipei ellet warsaa atain fu itacnim, no ahaa ain": "너는 생각을 말해라 에 대하여 돼지를 죽이는 것 칼로, 고기를 먹기 위해"
      }
    },
    "의문법": {
      "무엇": {
        "1": "slat [주제] hea? ([주제]는 무엇인가?)",
        "2": "hea? (뭐야?)"

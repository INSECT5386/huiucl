{
  "문법": {
    "어순": {
      "일반문 | [주어 수식] [주어] [부사어] [행위 명사] [목적어 수식] [목적어] [기타 부사구]": {
        "bomo rei jiu bei lin cie dal.": "나는 보살핀다 귀여운 돼지를",
        "in siu dei tin dal.": "사람은 이다 생각하는 동물",
        "bomo dau como selle mi.": "나는 그것을 줄 것이다 너에게",
        "bomo lau 13 ellum kili.": "나는 놀 것이다 13시에"
      },
      "복합문 | [주어 수식] [주어] [부사어] [행위 명사] [배경 정보] nu [하위 문장]": {
        "bomo tie kala jiu vum haliospoxli nu cie lin in dau jiu selle zomo": "나는 보았다 세상의 왼쪽에서 (nu 이하를) 뚱뚱한 사람이 무기를 주다 그에게"
      },
      "목적문 | [주어 수식] [주어] [부사어1] [행위 명사1] [목적어 수식1] [목적어1] no [목적어 수식2] [목적어2] [부사어2] [행위 명사2]": {
        "bomo rei jiu bei lin cie dal no mu vei jiu bie hil.": "나는 보살핀다 귀여운 돼지를 위해 음식을 산다."
      },
      "요청문 | [주어 수식] [주어] [행위 명사] -mo [목적어 수식] [목적어] [부사어] [기타 부사구]": {
        "mi mu bie jiu mo bie hil no zama": "당신은 요리해주세요 음식을. 그들을 위해"
      },
      "이유/피동문 | [대상 수식] [대상] cotum, [주어 수식] [주어] [부사어] [행위 명사] [기타 부사구]": {
        "zomo cotum, inz pei kolo jiu vum kin.": "그 때문에, 사람들이 다쳤다 집에서"
      },
      "명령문 | il [주어 수식] [주어] [행위 명사] [목적어 수식] [목적어] [부사어] [기타 부사구]": {
        "il mi rei vum vai.": "너는 사람을 도와라. 학교에서"
      }
    },
    "의문법": {
      "무엇": {
        "1": "slat [주제] hea? ([주제]는 무엇인가?)",
        "2": "hea? (뭐야?)"
      },
      "왜": {
        "1": "slat [문장] xea? (왜 [문장]입니까?)",
        "2": "xea? (왜?)"
      },
